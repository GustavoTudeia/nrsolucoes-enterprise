# App
ENV=dev
APP_NAME=NRSolucoes API
APP_VERSION=1.0.0
AUTO_CREATE_SCHEMA=true
AUTO_MIGRATE_SCHEMA=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Bootstrap (primeiro acesso) ---
# Para um ambiente totalmente novo, defina estas variáveis para criar
# um usuário Platform Admin automaticamente no startup (idempotente).
#
# Em produção: use uma única vez, faça login, troque a senha e remova/rotacione
# as variáveis.
BOOTSTRAP_PLATFORM_ADMIN_EMAIL=platform@nrsolucoes.com.br
BOOTSTRAP_PLATFORM_ADMIN_PASSWORD=CHANGE_ME
BOOTSTRAP_PLATFORM_ADMIN_NAME=Platform Admin
# Opcional: se você quiser que o Platform Admin também tenha contexto de tenant
# (para acessar telas tenant-scoped), informe o UUID do tenant.
# BOOTSTRAP_PLATFORM_ADMIN_TENANT_ID=

# Security
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg2://nr:nr@localhost:5432/nrsolucoes

# LGPD / Diagnóstico
DEFAULT_MIN_ANON_THRESHOLD=5

# Billing (Stripe)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# Worker (RQ)
REDIS_URL=redis://localhost:6379/0

# Portal do colaborador (apenas DEV)
# Em produção, mantenha DEV_RETURN_OTP=false e DEV_RETURN_PASSWORD_RESET_TOKEN=false.
DEV_RETURN_OTP=false
DEV_RETURN_PASSWORD_RESET_TOKEN=false

# (Opcional) utilitário local
API_BASE_URL=http://localhost:8000
