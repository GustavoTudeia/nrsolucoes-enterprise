# Backend base URL (server-side). Example local:
BACKEND_BASE_URL=http://localhost:8000/api/v1

# Optional: if you run on https and want secure cookies
COOKIE_SECURE=false

# --- Support / WhatsApp ---
# Phone number (digits only, include country code). Example Brazil:
NEXT_PUBLIC_SUPPORT_WHATSAPP=5511999999999

# Optional default message (will be prefixed with user/tenant context in-console)
NEXT_PUBLIC_SUPPORT_WHATSAPP_MSG=Olá! Preciso de suporte.
